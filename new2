<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>GPS Cam Pro v4.1</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <style>
        :root {
            --glass: rgba(0, 0, 0, 0.75);
            --border: rgba(255, 255, 255, 0.15);
            --accent: #007AFF;
        }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background: #000; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: white; overflow: hidden;
        }

        /* Video Container */
        #viewport { position: relative; width: 100vw; height: 100vh; overflow: hidden; background: #000; }
        video { 
            width: 100%; height: 100%; object-fit: cover; 
            transition: transform 0.2s ease-out; /* Smooth Zoom */
        }

        /* Sidebar Photo Stream */
        #sidebar {
            position: absolute; right: 12px; top: 100px; bottom: 180px;
            width: 70px; display: flex; flex-direction: column; gap: 10px;
            overflow-y: auto; z-index: 20; scrollbar-width: none;
        }
        #sidebar::-webkit-scrollbar { display: none; }
        .thumb {
            width: 60px; height: 60px; border-radius: 8px; border: 2px solid white;
            object-fit: cover; animation: slideIn 0.3s ease-out; box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        /* Zoom Slider */
        #zoom-container {
            position: absolute; left: 20px; top: 50%; transform: translateY(-50%);
            height: 200px; display: flex; flex-direction: column; align-items: center; z-index: 20;
        }
        #zoom-slider {
            appearance: none; width: 4px; height: 180px; background: rgba(255,255,255,0.3);
            border-radius: 2px; writing-mode: bt-lr; -webkit-appearance: slider-vertical;
        }

        /* Glassmorphic Data Card (The Watermark Look) */
        #overlay-card {
            position: absolute; bottom: 130px; left: 50%; transform: translateX(-50%);
            width: 90%; max-width: 420px;
            background: var(--glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border); border-radius: 15px;
            padding: 12px; display: flex; gap: 12px; align-items: center; z-index: 10;
        }
        #mini-map { width: 90px; height: 90px; border-radius: 10px; flex-shrink: 0; background: #222; }
        .meta { flex: 1; overflow: hidden; }
        .meta h3 { margin: 0; font-size: 15px; font-weight: 600; color: #fff; }
        .meta p { margin: 3px 0 0; font-size: 11px; opacity: 0.9; line-height: 1.4; font-family: monospace; }
        .flag { font-size: 16px; margin-left: 5px; vertical-align: middle; }

        /* Controls */
        .bottom-bar {
            position: absolute; bottom: 0; width: 100%; height: 120px;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            display: flex; justify-content: space-around; align-items: center; z-index: 30;
        }
        .shutter-wrap {
            width: 80px; height: 80px; border-radius: 50%; border: 4px solid white;
            display: flex; align-items: center; justify-content: center;
        }
        #shutter-btn {
            width: 64px; height: 64px; background: white; border-radius: 50%; border: none;
            transition: transform 0.1s;
        }
        #shutter-btn:active { transform: scale(0.9); }
        
        .action-btn {
            background: rgba(255,255,255,0.15); border: none; border-radius: 50%;
            width: 50px; height: 50px; color: white; font-size: 20px; cursor: pointer;
        }

        #batch-badge {
            position: absolute; top: -5px; right: -5px; background: red;
            color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px;
        }

        /* Animations */
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
        
        .flash {
            position: fixed; inset: 0; background: white; z-index: 100;
            opacity: 0; pointer-events: none;
        }
        .flash.active { animation: flashAnim 0.2s; }
        @keyframes flashAnim { 0% { opacity: 0; } 50% { opacity: 0.8; } 100% { opacity: 0; } }

        canvas { display: none; }
    </style>
</head>
<body>

<div id="flash" class="flash"></div>

<div id="viewport">
    <video id="video" autoplay playsinline muted></video>

    <div id="sidebar"></div>

    <div id="zoom-container">
        <span style="font-size: 10px; margin-bottom: 5px;">+</span>
        <input type="range" id="zoom-slider" min="1" max="5" step="0.1" value="1">
        <span style="font-size: 10px; margin-top: 5px;">-</span>
    </div>

    <div id="overlay-card">
        <div id="mini-map"></div>
        <div class="meta">
            <h3><span id="ui-city">Bengaluru</span>, <span id="ui-state">Karnataka</span> <span class="flag">🇮🇳</span></h3>
            <p id="ui-addr">Locating address...</p>
            <p>
                <b>Lat:</b> <span id="ui-lat">0.000000</span>° <b>Long:</b> <span id="ui-lon">0.000000</span>°<br>
                <span id="ui-date">Thursday, 30/04/2026 11:18 AM</span>
            </p>
        </div>
    </div>

    <div class="bottom-bar">
        <button class="action-btn" onclick="toggleCamera()">🔄</button>
        
        <div class="shutter-wrap">
            <button id="shutter-btn"></button>
        </div>

        <div style="position: relative;">
            <button class="action-btn" onclick="downloadZip()">📦</button>
            <div id="batch-badge">0</div>
        </div>
    </div>
</div>

<canvas id="proc-canvas"></canvas>

<script>
    let currentStream = null;
    let facingMode = "environment";
    let photoBuffer = []; // Zero-lag storage
    let map, marker;
    let zoomLevel = 1;

    const video = document.getElementById('video');
    const badge = document.getElementById('batch-badge');
    const sidebar = document.getElementById('sidebar');

    // 1. Initialize App
    async function startCamera() {
        if (currentStream) currentStream.getTracks().forEach(t => t.stop());
        
        try {
            currentStream = await navigator.mediaDevices.getUserMedia({
                video: { 
                    facingMode: facingMode,
                    width: { ideal: 3840 }, 
                    height: { ideal: 2160 }
                }
            });
            video.srcObject = currentStream;
        } catch (e) { alert("Camera Error: " + e.message); }
    }

    function toggleCamera() {
        facingMode = (facingMode === "environment") ? "user" : "environment";
        startCamera();
    }

    // 2. High-Precision GPS
    function initGPS() {
        navigator.geolocation.watchPosition(async (pos) => {
            const { latitude, longitude } = pos.coords;
            document.getElementById('ui-lat').innerText = latitude.toFixed(6);
            document.getElementById('ui-lon').innerText = longitude.toFixed(6);
            document.getElementById('ui-date').innerText = new Date().toLocaleString('en-GB', { 
                weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric', 
                hour: '2-digit', minute: '2-digit', hour12: true 
            }) + " GMT +05:30";

            if (!map) {
                map = L.map('mini-map', { zoomControl: false, attributionControl: false }).setView([latitude, longitude], 16);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
                marker = L.marker([latitude, longitude]).addTo(map);
            } else {
                map.setView([latitude, longitude]);
                marker.setLatLng([latitude, longitude]);
            }

            // Reverse Geocoding
            try {
                const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latitude}&lon=${longitude}`);
                const data = await res.json();
                const addr = data.address;
                document.getElementById('ui-city').innerText = addr.city || addr.town || "Bengaluru";
                document.getElementById('ui-state').innerText = addr.state || "Karnataka";
                document.getElementById('ui-addr').innerText = data.display_name.split(',').slice(0, 3).join(',');
            } catch (e) {}
        }, null, { enableHighAccuracy: true });
    }

    // 3. Zoom Logic
    document.getElementById('zoom-slider').oninput = (e) => {
        zoomLevel = e.target.value;
        video.style.transform = `scale(${zoomLevel})`;
    };

    // 4. Zero-Lag Capture
    document.getElementById('shutter-btn').onclick = async () => {
        // Visual Feedback
        document.getElementById('flash').classList.add('active');
        setTimeout(() => document.getElementById('flash').classList.remove('active'), 200);

        const canvas = document.getElementById('proc-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;

        // Instant Frame Snap (with zoom crop)
        const sw = video.videoWidth / zoomLevel;
        const sh = video.videoHeight / zoomLevel;
        const sx = (video.videoWidth - sw) / 2;
        const sy = (video.videoHeight - sh) / 2;
        
        ctx.drawImage(video, sx, sy, sw, sh, 0, 0, canvas.width, canvas.height);

        // Save Raw Snapshot immediately to buffer
        const rawBlob = await new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.95));
        
        // Background Process: Map + Card
        processPhoto(rawBlob);
    };

    async function processPhoto(rawBlob) {
        // Create Sidebar Thumbnail instantly
        const imgUrl = URL.createObjectURL(rawBlob);
        const thumb = document.createElement('img');
        thumb.src = imgUrl;
        thumb.className = 'thumb';
        sidebar.prepend(thumb);

        // Capture Map image in background
        const mapElement = document.getElementById('overlay-card');
        const mapImg = await html2canvas(mapElement, { useCORS: true, scale: 2, backgroundColor: null });

        // Merge Everything
        const finalCanvas = document.createElement('canvas');
        finalCanvas.width = video.videoWidth;
        finalCanvas.height = video.videoHeight;
        const fctx = finalCanvas.getContext('2d');

        // Draw snapped photo
        const tempImg = new Image();
        tempImg.src = imgUrl;
        await new Promise(r => tempImg.onload = r);
        fctx.drawImage(tempImg, 0, 0);

        // Draw the Overlay Card at bottom center
        const cardW = finalCanvas.width * 0.45;
        const cardH = (mapImg.height / mapImg.width) * cardW;
        fctx.drawImage(mapImg, (finalCanvas.width - cardW) / 2, finalCanvas.height - cardH - 100, cardW, cardH);

        // Push to ZIP Buffer
        const finalBlob = await new Promise(res => finalCanvas.toBlob(res, 'image/jpeg', 0.9));
        photoBuffer.push(finalBlob);
        badge.innerText = photoBuffer.length;
    }

    async function downloadZip() {
        if (photoBuffer.length === 0) return alert("Take some photos first!");
        
        const zip = new JSZip();
        photoBuffer.forEach((blob, i) => {
            zip.file(`GPS_Photo_${i+1}.jpg`, blob);
        });

        const content = await zip.generateAsync({type:"blob"});
        const link = document.createElement('a');
        link.href = URL.createObjectURL(content);
        link.download = `GPS_Batch_${Date.now()}.zip`;
        link.click();

        // Clear
        photoBuffer = [];
        badge.innerText = "0";
        sidebar.innerHTML = "";
    }

    startCamera();
    initGPS();
</script>

</body>
</html>
